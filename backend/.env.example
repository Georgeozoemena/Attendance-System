PORT=4000
# Google Apps Script webhook URL (deploy as Web App)
APPS_SCRIPT_WEBHOOK=https://script.google.com/macros/s/AKfycbzFGWAe3Ldz5jWR2gxWg-dmpJ2RfbfOA8J-ZINCg2Ofg9RZP-1CCPR3ahvsHPQDf5R6tw/exec
# Optional API key matching SCRIPT_KEY in Apps Script
APPS_SCRIPT_KEY=script_key_here
ADMIN_PASSWORD=your_secure_password

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# WhatsApp Configuration (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# SMS Configuration (Twilio)
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_PHONE_NUMBER=+1234567890