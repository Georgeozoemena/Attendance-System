PORT=4000

# Google Apps Script webhook URL
APPS_SCRIPT_WEBHOOK=your_apps_script_url
# Optional API key matching SCRIPT_KEY in Apps Script
APPS_SCRIPT_KEY=your_script_key

# Password for the Admin Dashboard - use a strong password in production
ADMIN_PASSWORD=change_me_in_production

# Secret used to sign session tokens - generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
SESSION_SECRET=generate_a_random_32_byte_hex_string

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Turso Cloud Database
LIBSQL_URL=libsql://your-db-instance.turso.io
LIBSQL_AUTH_TOKEN=your_auth_token

# AI API Keys (Optional - only one required for Assistant)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Messaging (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
